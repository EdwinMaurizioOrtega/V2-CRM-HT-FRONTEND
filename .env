# Docs: https://uanataca-team.atlassian.net/wiki/external/ZjJjZjA1MjBlMWNhNGU4ODhkMzYyMTE4MDQ1OTgyYTc
#
# Host sandbox:   https://api-test.uanatacaec.com/flows
# Host prod:      https://api.uanatacaec.com/flows
NEXT_PUBLIC_UANATACA_HOST=https://api-test.uanatacaec.com/flows

# Pasarela de firma (link que abre el firmante). Cambia a produccion
# (https://pasarelafirma.uanatacaec.com) al salir de sandbox.
NEXT_PUBLIC_UANATACA_SIGN_PORTAL=https://pasarelafirma-sandbox.uanatacaec.com

# Prefijo legacy que se guarda en la columna SSO (se concatena con /<flowId>).
NEXT_PUBLIC_UANATACA_SSO_PREFIX=https://hypertronics.nexxit.dev/#sso//api/uanataca/v2/flows

# Webhook obligatorio por la API (aunque no lo usamos internamente);
# puede ser un placeholder publico tipo webhook.site
NEXT_PUBLIC_UANATACA_WEBHOOK_URL=https://webhook.site/replace-me

